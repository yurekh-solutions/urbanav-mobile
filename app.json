    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "light",
    "primaryColor": "#7B25F4",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
