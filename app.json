    "web": {
      "name": "UrbanAV — AV Rental Marketplace",
      "shortName": "UrbanAV",
      "description": "Post your event requirement, get matched with top AV vendors, book with secure advance + OTP trust layer.",
      "themeColor": "#7B25F4",
      "backgroundColor": "#EFEAF4",
      "favicon": "./assets/logo.jpg"
    }
  }
